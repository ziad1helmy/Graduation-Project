# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/lifelink
# Optional legacy alias still supported by code:
# MONGODB_URI=mongodb://localhost:27017/lifelink

# JWT
JWT_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# App
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000
CORS_ORIGIN=*
# Legacy variable kept for backward compatibility (currently not used by route mounting)
API_PREFIX=/api
BCRYPT_SALT_ROUNDS=10

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace_with_smtp_password
MAIL_FROM="LifeLink <no-reply@lifelink.com>"
EMAIL_LOGO_URL=https://example.com/path/to/logo.png

# Firebase Cloud Messaging (FCM) - Push Notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
# Optional alternative to the three vars above. Path is relative to project root.
# FIREBASE_SERVICE_ACCOUNT_PATH=service-account.json
