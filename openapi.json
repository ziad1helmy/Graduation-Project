    "/hospital/request": {
      "post": {
        "tags": [
          "Hospital"
        ],
        "summary": "Create a donation request",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "urgency",
                  "requiredBy"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "blood",
                      "organ"
                    ],
                    "example": "blood"
                  },
                  "bloodType": {
                    "type": "string",
                    "enum": [
                      "A+",
                      "A-",
                      "B+",
